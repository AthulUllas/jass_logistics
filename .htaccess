<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve static files and directories directly (images, CSS, JS, PHP files)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php (for SPA-style routing)
    RewriteRule ^ index.php [L]
</IfModule>

# PHP upload limits
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
</IfModule>

# Security: block direct browser access to sensitive backend files
<FilesMatch "(database\.php|\.env|data\.json|admin\.json|server\.js|package(-lock)?\.json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
