{
    "version": 2,
    "name": "jass-logistics-frontend",
    "builds": [
        {
            "src": "**/*.{html,js,css,png,jpg,jpeg,svg,gif,webp,ico}",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/(admin/?)",
            "destination": "/admin/index.html"
        }
    ]
}